<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <%= govuk_notification_banner(title_text: t('notification_banner.info')) do |notification_banner| %>
      <% notification_banner.with_heading(text: header_content) %>
        <% if body_content.present? %>
            <%= GovukMarkdown.render(body_content).html_safe %>
        <% end %>
    <% end %>
  </div>
</div>
