<div class="govuk-grid-column-full">
  <h2 class="govuk-heading-m"><%= title %></h2>

  <% serialized_statistics.each do |data| %>
    <%= govuk_table(html_attributes: { class: 'govuk-!-margin-bottom-8' }) do |table| %>
      <%= table.with_caption do %>
        <h3 class="govuk-body govuk-!-margin-bottom-0"><%= subcategory %></h3>
      <% end %>

      <%= table.with_head do |head| %>
        <%= head.with_row do |row| %>
          <%= row.with_cell(scope: false, html_attributes: { class: 'th-border-none' }) %>
          <%= row.with_cell(scope: false, html_attributes: { class: 'th-border-none' }) %>
          <% table_headers.each do |header| %>
            <%= row.with_cell(text: header, html_attributes: { class: 'govuk-!-text-align-right th-border-none' }) %>
          <% end %>
        <% end %>
      <% end %>

      <%= table.with_body do |body| %>
        <% rows(data).each do|edi_row| %>
          <%= body.with_row do |row| %>
            <% if edi_row.stats_for.present? %>
              <%= row.with_cell(rowspan: 2, header: true, text: edi_row.stats_for) %>
            <% end %>
            <%= row.with_cell(
              header: true,
              text: edi_row.cycle,
              html_attributes: { class: edi_row.stats_for.present? ? 'th-border-none' : '' },
            ) %>

            <%= row.with_cell(
              text: edi_row.applied,
              numeric: true,
              html_attributes: { class: edi_row.stats_for.present? ? 'th-border-none' : '' },
            ) %>
            <%= row.with_cell(
              text: edi_row.offered,
              numeric: true,
              html_attributes: { class: edi_row.stats_for.present? ? 'th-border-none' : '' },
            ) %>
            <%= row.with_cell(
              text: edi_row.recruited,
              numeric: true,
              html_attributes: { class: edi_row.stats_for.present? ? 'th-border-none' : '' },
            ) %>

            <%= row.with_cell(
              text: edi_row.percentage_recruited,
              numeric: true,
              html_attributes: { class: edi_row.stats_for.present? ? 'th-border-none' : '' },
            ) %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
