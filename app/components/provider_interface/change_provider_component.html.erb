<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    <%= form_with model: form_object, url: provider_interface_offer_provider_path, method: :post do |f| %>
      <%= f.govuk_radio_buttons_fieldset :provider_id,
        legend: { text: page_title, size: 'l' },
        caption: { text: full_name, size: 'l' } do %>

        <% providers.each_with_index do |provider, i| %>
          <%= f.govuk_radio_button :provider_id,
            provider.id,
            label: { text: provider.name_and_code },
            link_errors: i.zero? %>
        <% end %>
      <% end %>
      <%= f.govuk_submit t('continue') %>
    <% end %>

    <p class="govuk-body">
      <%= govuk_link_to 'Cancel', provider_interface_application_choice_path(application_choice.id), class: 'govuk-link--no-visited-state' %>
    </p>
  </div>
</div>
