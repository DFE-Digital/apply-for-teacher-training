<% if action == :withdraw %>
  <% if FeatureFlag.active? :new_candidate_withdrawal_reasons %>
    <p class="govuk-body">
      <%= govuk_link_to 'Withdraw this application', candidate_interface_withdrawal_reasons_primary_reason_start_path(application_choice.id) %>
    </p>
  <% else %>
    <p class="govuk-body">
      <%= govuk_link_to 'Withdraw this application', candidate_interface_withdraw_path(application_choice.id) %>
    </p>
  <% end %>
<% elsif action == :respond_to_offer %>
  <p class="govuk-body">
    <%= govuk_link_to 'Respond to offer', candidate_interface_offer_path(application_choice.id) %>
  </p>
<% end %>
