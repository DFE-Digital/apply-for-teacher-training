<% content_for :title, title_with_error_prefix(t('page_titles.residency_date', country: @country_of_residence), @residency_date_form.errors.any?) %>
<% content_for :before_content, govuk_back_link_to(@back_path) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-three-quarters">
    <%= form_with(model: @residency_date_form, url: candidate_interface_edit_residency_date_path, method: :patch) do |f| %>
      <%= f.govuk_error_summary %>

      <%= f.govuk_date_field(:date, month: :start_date_month, year: :start_date_year, omit_day: true, legend: { size: 'l', text: t('application_form.contact_details.residency_date.legend', country: @country_of_residence) }, hint: { text: t('application_form.contact_details.residency_date.hint') }, link_errors: true) %>

      <%= f.govuk_submit 'Continue' %>
    <% end %>
  </div>
</div>
