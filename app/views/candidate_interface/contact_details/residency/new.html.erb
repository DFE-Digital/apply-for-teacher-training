<% content_for :title, title_with_error_prefix(t('page_titles.residency', country: @country_of_residence), @residency_form.errors.any?) %>
<% content_for :before_content, govuk_back_link_to(candidate_interface_new_address_path) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-three-quarters">
    <%= form_with(model: @residency_form, url: candidate_interface_residency_path, method: :post) do |f| %>
      <%= f.govuk_error_summary %>

      <%= f.govuk_radio_buttons_fieldset(:since_birth, legend: { size: 'l', tag: 'h1', text: t('application_form.contact_details.residency.label', country: @country_of_residence) }, hint: { text: t('application_form.contact_details.residency.hint') }) do %>
        <%= f.govuk_radio_button :since_birth, 'yes', label: { text: 'Yes' }, link_errors: true %>
        <%= f.govuk_radio_button :since_birth, 'no', label: { text: 'No' } %>
      <% end %>

      <%= f.govuk_submit 'Save and continue' %>
    <% end %>
  </div>
</div>
