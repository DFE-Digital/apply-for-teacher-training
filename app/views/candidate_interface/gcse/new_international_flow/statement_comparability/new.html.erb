<% content_for :title, title_with_error_prefix(grade_enic_step_title((@subject == 'english' ? @subject.capitalize : @subject)), @enic_form.errors.any?) %>
<% content_for :before_content, govuk_back_link_to(candidate_interface_gcse_new_international_flow_new_enic_path(@subject)) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= form_with model: @enic_form, url: @form_path, method: :patch do |f| %>
      <%= render 'form', f: f %>
    <% end %>
  </div>
</div>
