<% content_for :title, t('gcse_new_international_flow_interruption.page_title', subject: @subject.capitalize) %>
<% content_for :before_content, govuk_back_link_to(candidate_interface_gcse_new_international_flow_new_grades_path) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-three-quarters">
    <div class="app-grid-column--grey">
      <h1 class="govuk-heading-l">This grade may not be equivalent to a GCSE in <%= @subject.capitalize %> at Grade 4 (C) or above</h1>

      <p class="govuk-body">You need the equivalent of a GCSE at grade 4 (C) or above to apply for teacher training. You can provide evidence that your <%= @subject.capitalize %> skills are equivalent to this on the next page.</p>
        <p class="govuk-body">
        Some providers may let you do an equivalency test to show you have the required skills.
        </p>
    </div>

  <div class="govuk-button-group app-course-choice__confirm-submission">
    <%= govuk_link_to('Continue', candidate_interface_gcse_new_international_flow_new_evidence_path) %>
  <div>

  </div>
</div>
