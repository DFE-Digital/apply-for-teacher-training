<% content_for :title, t('candidate_interface.withdrawal_reasons.primary_reason_title') %>
<% content_for :before_content, govuk_back_link_to(candidate_interface_course_choices_course_review_path(@application_choice), back_link_text, force_text: true) %>
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= form_with(model: @withdrawal_reason_form, url: candidate_interface_withdrawal_reason_continue_path) do |f| %>
      <%= f.govuk_error_summary %>
      <%= f.hidden_field(:form_step, value: 'primary_reason') %>
      <%= f.govuk_radio_buttons_fieldset(
        :primary_reason,
        legend: { text: t('candidate_interface.withdrawal_reasons.primary_reason_title'), tag: 'h1', size: 'l' }
      ) do %>
        <% @withdrawal_reason_form.primary_reason_options.each_with_index do |r, index| %>
          <% if r.text_area_label.blank? %>
            <%= f.govuk_radio_button(
                  :primary_reason,
                  r.id,
                  link_errors: index.zero?,
                  label: { text: r.name, }
                ) %>
          <% else %>
            <%= f.govuk_radio_button(
              :primary_reason,
              r.id,
              label: { text: r.name, }
            )  do %>
              <%= f.govuk_text_area(
                    :primary_other_comment,
                    label: { text: r.text_area_label, size: 's' },
                    max_words: 200,
                    rows: 5,
                    link_errors: true
                  ) %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
      <%= f.govuk_submit t('continue') %>
    <% end %>
  </div>
</div>
