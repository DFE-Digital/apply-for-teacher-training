<% content_for :title, t('page_titles.decisions.withdraw') %>
<% content_for :before_content, govuk_back_link_to(candidate_interface_details_path, back_link_text, force_text: true) %>
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= form_with(model: @withdrawal_reason_form, url: candidate_interface_withdrawal_reason_continue_path) do |f| %>
      <%= f.govuk_error_summary %>

      <%= f.govuk_radio_buttons_fieldset(
            :reason,
            legend: { text: 'Why are you withdrawing this application?', tag: 'h1', size: 'l' }
          ) do %>
        <% @withdrawal_reason_form.initial_options.each_with_index do |r, index| %>
          <% if r.text_area_label.blank? %>
            <%= f.govuk_radio_button(
                  :reason,
                  r.id,
                  link_errors: index.zero?,
                  label: { text: r.name, }
                ) %>
          <% else %>
            <%= f.govuk_radio_button(
                  :reason,
                  r.id,
                  label: { text: r.name, }
                )  do %>
              <%= f.govuk_text_area(
                    :comment,
                    label: { text: r.text_area_label, size: 's' },
                    max_chars: 256,
                    rows: 5,
                    link_errors: true
                  ) %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
      <%= f.govuk_submit t('continue') %>
    <% end %>
  </div>
</div>
