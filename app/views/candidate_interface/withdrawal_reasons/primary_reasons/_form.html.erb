<%= form_with(
      model: @primary_reasons_form,
      url: candidate_interface_withdrawal_reasons_primary_reason_continue_path(withdrawal_reason_id: @primary_reasons_form.id),
    ) do |f| %>
  <%= f.govuk_error_summary %>
  <%= f.govuk_radio_buttons_fieldset(
    :primary_reason,
    legend: { text: t('candidate_interface.withdrawal_reasons.primary_reason_title'), tag: 'h1', size: 'l' },
  ) do %>
    <% @primary_reasons_form.reason_options.each_with_index do |reason, index| %>
      <% if reason.text_area_label.blank? %>
        <%= f.govuk_radio_button(
              :primary_reason,
              reason.id,
              link_errors: index.zero?,
              label: { text: reason.name },
            ) %>
      <% else %>
        <%= f.govuk_radio_button(
          :primary_reason,
          reason.id,
          label: { text: reason.name },
        )  do %>
          <%= f.govuk_text_area(
                :comment,
                label: { text: reason.text_area_label, size: 's' },
                max_words: 200,
                rows: 5,
                link_errors: true,
              ) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
  <%= f.govuk_submit t('continue') %>
<% end %>
