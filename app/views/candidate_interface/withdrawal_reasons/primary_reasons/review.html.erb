<% content_for :title, t('page_titles.decisions.withdraw') %>
<% content_for :before_content, govuk_back_link_to(candidate_interface_withdrawal_reasons_primary_reason_start_path, 'Back', force_text: true) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-l"><%= t('page_titles.decisions.withdraw') %></h1>
    <%= govuk_summary_list do |summary_list| %>
      <% summary_list.with_row do |row| %>
        <% row.with_key(text: 'Provider') %>
        <% row.with_value(text: @application_choice.current_course.provider.name) %>
      <% end %>
      <% summary_list.with_row do |row| %>
        <% row.with_key(text: 'Course') %>
        <% row.with_value(text: @application_choice.current_course.name_and_code) %>
      <% end %>
      <% summary_list.with_row do |row| %>
        <% row.with_key(text: 'Reason') %>
        <% row.with_value(text: @primary_reasons_form.primary_reason_text) %>
        <% row.with_action(
             text: 'Change',
             href: candidate_interface_withdrawal_reasons_primary_reason_edit_path,
             visually_hidden_text: 'reason for withdrawal',
           ) %>
      <% end %>
    <% end %>

    <%= form_with(
          model: @primary_reasons_form,
          url: candidate_interface_withdrawal_reasons_primary_reason_withdraw_path(@application_choice, @primary_reason),
          method: :post,
        ) do |f| %>

      <%= f.govuk_submit 'Yes I’m sure – withdraw this application', warning: true %>
    <% end %>

    <p class="govuk-body">
      <%= govuk_button_to(
            t('cancel'),
            candidate_interface_withdrawal_reasons_primary_reason_cancel_path(@application_choice),
            form_class: 'govuk-link',
            class: 'govuk-link--no-visited-state',
          ) %>
    </p>
  </div>
</div>
