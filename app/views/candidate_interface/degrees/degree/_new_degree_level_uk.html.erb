<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <% content_for :title, title_with_error_prefix(t('page_titles.degree_level'), @wizard.errors.any?) %>
    <% content_for :before_content, govuk_back_link_to(@wizard.back_link) %>

    <%= form_with(
          model: @wizard,
          url: candidate_interface_degree_degree_level_path,
          scope: :candidate_interface_degree_wizard,
          method: :post,
        ) do |f| %>
      <%= f.govuk_error_summary %>

      <%= f.govuk_radio_buttons_fieldset :degree_level, legend: { text: 'What type of degree is it?', tag: 'h1', size: 'l' } do %>
        <% @wizard.degree_level_options.each_with_index do |name, index| %>
          <% if name ==  @wizard.uk_other_option %>
            <%= f.govuk_radio_divider %>

            <%= f.govuk_radio_button :degree_level, name, label: { text: name } do %>
              <%= f.govuk_text_field :equivalent_level, label: { text: 'Qualification type' } %>
            <% end %>
          <% else %>
            <%= f.govuk_radio_button :degree_level, name, label: { text: name }, hint: -> { tag.span(t('application_form.degree.level.hint.bachelor_degree')) if name == 'Bachelor degree' }, link_errors: index.zero? %>
          <% end %>
        <% end %>
      <% end %>
      <%= f.govuk_submit t('save_and_continue') %>
    <% end %>
  </div>
</div>
