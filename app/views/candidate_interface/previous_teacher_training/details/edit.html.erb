<% content_for :browser_title, title_with_error_prefix(t('.title'), @form.errors.any?) %>
<% content_for :before_content, govuk_back_link_to(@back_path || edit_candidate_interface_previous_teacher_training_dates_path) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= form_with(
      model: @form,
      url: candidate_interface_previous_teacher_training_details_path,
      method: :put
    ) do |f| %>
      <%= f.govuk_error_summary %>

      <%= f.govuk_text_area(
        :details,
        label: { text: t('.title'), size: 'xl' },
        hint: { text: t('.hint_html') },
        rows: 10,
        max_words: 500
      ) %>

      <%= f.govuk_submit %>
    <% end %>
    <%# can we remove the method? %>
  </div>
</div>
