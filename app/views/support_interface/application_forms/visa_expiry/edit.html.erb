<% content_for :title, title_with_error_prefix(t('page_titles.edit_applicant_visa_expiry'), @form.errors.any?) %>
<% content_for :before_content, govuk_back_link_to(support_interface_application_form_path(@application_form)) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= form_with model: @form, url: support_interface_visa_expiry_path(@application_form), method: :patch do |f| %>
      <%= f.govuk_error_summary %>

      <%= f.govuk_date_field :visa_expired_at, legend: { text: 'When does your visa expire?', size: 'l' } %>

      <%= f.govuk_text_field(
        :audit_comment,
        label: { text: 'Audit log comment', size: 'm' },
        hint: { text: 'This will appear in the audit log alongside this change. If the change originated in a Zendesk ticket, paste the Zendesk URL here' },
      ) %>

      <%= f.govuk_submit t('save_and_continue') %>
    <% end %>
  </div>
</div>
