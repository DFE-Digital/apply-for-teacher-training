<% content_for :title, t('page_titles.configure_service_banner', interface: @interface) %>
<% content_for :before_content, govuk_back_link_to(support_interface_edit_show_service_banner_path(interface: @interface)) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-three-quarters">
    <%= form_with(model: @configure_service_banner_form, url: support_interface_update_configure_service_banner_path(interface: @interface), method: :patch) do |f| %>
      <%= f.govuk_error_summary %>

      <%= f.govuk_text_field :banner_header, label: { text: t('.banner_header_label'), size: 'm' }, link_errors: true %>

      <%= f.govuk_text_area :banner_content, label: { text: t('.banner_content_label'), size: 'm' }, hint: { text: t('.caption') }, max_chars: 400, link_errors: true %>

      <%= f.govuk_submit t('.preview') %>
    <% end %>
  </div>
</div>
