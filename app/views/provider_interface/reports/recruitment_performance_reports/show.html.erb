<%= content_for :title, t('.title', cycle_year: @recruitment_cycle_year) %>
<%= content_for(
  :before_content,
  breadcrumbs(
    t('page_titles.provider.reports') => provider_interface_reports_path,
    t('page_titles.provider_recruitment_performance_report', cycle_year: @recruitment_cycle_year) => nil,
  ),
) %>

<% if @reports_ready %>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <%= govuk_notification_banner(title_text: 'Important') do |notification_banner| %>
        <% notification_banner.with_heading(text: 'Tell us what you think of the changes to this report') %>
        <p class="govuk-body">
          <%= govuk_link_to 'Give us your feedback', 'https://dferesearch.fra1.qualtrics.com/jfe/form/SV_cuOh0pL2oj64yKa' %> to help improve reports.
        </p>
      <% end %>

      <h1 class="govuk-heading-l">
        <%= t(
          'page_titles.provider_recruitment_performance_report',
          cycle_year: @recruitment_cycle_year,
        ) %>
      </h1>
      <p class="govuk-body">
        <%= govuk_link_to 'Export data (ZIP)', provider_interface_reports_provider_recruitment_performance_report_path(provider_id: @provider, format: :zip) %>
      </p>
    </div>

    <%= render RecruitmentPerformanceReport::ReportMethodologyComponent.new(
      provider_report: @provider_report,
      comparison_link: new_provider_interface_reports_provider_regional_report_filter_path(
        recruitment_cycle_year: @provider_report.recruitment_cycle_year,
      ),
    ) %>
    <%= render RecruitmentPerformanceReport::SubmittedApplicationsTableComponent.new(
      @provider,
      @provider_data,
      @statistics,
      report_type: @report_type,
      region: @region,
      recruitment_cycle_year: @provider_report.recruitment_cycle_year,
    ) %>
    <%= render RecruitmentPerformanceReport::CandidatesWithOffersTableComponent.new(
      @provider,
      @provider_data,
      @statistics,
      report_type: @report_type,
      region: @region,
      recruitment_cycle_year: @provider_report.recruitment_cycle_year,
    ) %>
    <%= render RecruitmentPerformanceReport::ProportionCandidatesWithOffersTableComponent.new(
      @provider,
      @provider_data,
      @statistics,
      report_type: @report_type,
      region: @region,
      recruitment_cycle_year: @provider_report.recruitment_cycle_year,
    ) %>
    <%= render RecruitmentPerformanceReport::OffersAcceptedTableComponent.new(
      @provider,
      @provider_data,
      @statistics,
      report_type: @report_type,
      region: @region,
      recruitment_cycle_year: @provider_report.recruitment_cycle_year,
    ) %>
    <%= render RecruitmentPerformanceReport::DeferralsTableComponent.new(
      @provider,
      @provider_data,
      @statistics,
      report_type: @report_type,
      region: @region,
      recruitment_cycle_year: @provider_report.recruitment_cycle_year,
    ) %>
    <%= render RecruitmentPerformanceReport::CandidatesRejectedTableComponent.new(
      @provider,
      @provider_data,
      @statistics,
      report_type: @report_type,
      region: @region,
      recruitment_cycle_year: @provider_report.recruitment_cycle_year,
    ) %>
    <%= render RecruitmentPerformanceReport::ProportionWithInactiveApplicationsTableComponent.new(
      @provider,
      @provider_data,
      @statistics,
      report_type: @report_type,
      region: @region,
      recruitment_cycle_year: @provider_report.recruitment_cycle_year,
    ) %>

    <% if FeatureFlag.active?(:provider_edi_report) %>
      <%= render RecruitmentPerformanceReport::EdiReportDescription.new(
        provider_report: @provider_report,
      ) %>

      <%= render RecruitmentPerformanceReport::AgeGroupComponent.new(
        provider: @provider,
        edi_reports: @provider_edi_reports,
        region: @region,
      ) %>

      <%= render RecruitmentPerformanceReport::DisabilityComponent.new(
        provider: @provider,
        edi_reports: @provider_edi_reports,
        region: @region,
      ) %>

      <%= render RecruitmentPerformanceReport::DisabilityDeclarationComponent.new(
        provider: @provider,
        edi_reports: @provider_edi_reports,
        region: @region,
      ) %>

      <%= render RecruitmentPerformanceReport::EthnicGroupComponent.new(
        provider: @provider,
        edi_reports: @provider_edi_reports,
        region: @region,
      ) %>

      <%= render RecruitmentPerformanceReport::SexComponent.new(
        provider: @provider,
        edi_reports: @provider_edi_reports,
        region: @region,
      ) %>
    <% end %>
  </div>
<% else %>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">
        <%= t(
          'page_titles.provider_recruitment_performance_report',
          cycle_year: @recruitment_cycle_year,
        ) %>
      </h1>
      <p class="govuk-body"><%= t('.not_ready_to_view') %></p>

      <% if RecruitmentPerformanceReportTimetable.report_season? %>
        <%= govuk_link_to(
          'Set your comparison area',
          new_provider_interface_reports_provider_regional_report_filter_path(
            recruitment_cycle_year: @recruitment_cycle_year,
          ),
          class: 'govuk-button govuk-button--secondary',
        ) %>
      <% end %>
    </div>
  </div>
<% end %>
